# Environment Variables for Kids Education App
# Copy this file to .env and fill in your API keys

# ============================================
# LLM API KEYS (Get free API keys from below)
# ============================================

# 1. GROQ API (RECOMMENDED - Ultra Fast & Free)
# Sign up: https://console.groq.com/
# Free tier: 14,400 requests/day, 30 requests/minute
GROQ_API_KEY=your_groq_api_key_here

# 2. GOOGLE GEMINI API (High Quality & Free)
# Get key: https://makersuite.google.com/app/apikey
# Free tier: 15 requests/minute, 1500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# 3. HUGGINGFACE API (Free Inference)
# Get key: https://huggingface.co/settings/tokens
# Free tier: Rate-limited but sufficient
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ============================================
# NOTES
# ============================================
# - You need at least ONE API key for the app to work
# - The agent will automatically use available APIs
# - Groq is recommended for fastest generation
# - All three are FREE with generous limits
